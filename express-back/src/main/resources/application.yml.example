server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/express_station?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
    username: root
    password: YOUR_PASSWORD_HERE
    driver-class-name: com.mysql.cj.jdbc.Driver

mybatis:
  mapper-locations: classpath:mapper/*.xml
  type-aliases-package: com.example.kuaidi.entity
  configuration:
    map-underscore-to-camel-case: true

# JWT 配置
jwt:
  secret: YOUR_JWT_SECRET_HERE
  expiration: 86400000   # 24小时
